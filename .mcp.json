{
  "mcpServers": {
    "playwright": {
      "type": "stdio",
      "command": "npx",
      "args": ["@playwright/mcp@latest"],
      "env": {}
    },
    "context7": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp@latest"],
      "env": {}
    },
    "rabbitmq": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "mcp-server-rabbitmq@latest",
        "--rabbitmq-host", "localhost",
        "--port", "5672",
        "--username", "guest",
        "--password", "guest",
        "--api-port", "15672"
      ]
    }
  }
}